rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Deny-All Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 3. Entity-Specific Validation Blueprints
    
    // User Validation
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 256 &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
             data.createdAt == request.time;
    }

    // TryOnResult Validation
    function isValidTryOnResult(data) {
      return data.userId == request.auth.uid &&
             data.productId is string && data.productId.size() <= 128 &&
             data.deviceType in ['Mobile', 'Desktop'] &&
             data.createdAt == request.time;
    }

    // Product Validation (Admin only)
    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.transparentImageUrl is string && data.transparentImageUrl.size() <= 2048;
    }

    // 4. Collection Matches

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && 
                      incoming().keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
                      incoming().keys().size() <= 5 &&
                      isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']) &&
                      isValidUser(incoming());
    }

    match /tryOnResults/{resultId} {
      allow create: if isSignedIn() && 
                      incoming().keys().hasAll(['userId', 'productId', 'deviceType', 'createdAt']) &&
                      incoming().keys().size() == 4 &&
                      isValidTryOnResult(incoming());
      allow read: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && adminId == request.auth.uid;
      allow write: if false; // System-managed
    }

    // Internal test connection helper
    match /test/connection {
      allow read: if true;
    }
  }
}
